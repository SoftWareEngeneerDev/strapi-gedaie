{
  "kind": "collectionType",
  "collectionName": "decision_edges",
  "info": {
    "singularName": "decision-edge",
    "pluralName": "decision-edges",
    "displayName": "Decision Edge",
    "description": "Lien entre deux nœuds d'un arbre décisionnel"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "edgeId": {
      "type": "string",
      "required": true
    },
    "source": {
      "type": "string",
      "required": true
    },
    "target": {
      "type": "string",
      "required": true
    },
    "label": {
      "type": "string"
    },
    "decision_tree": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::decision-tree.decision-tree",
      "inversedBy": "decision_edges"
    }
  }
